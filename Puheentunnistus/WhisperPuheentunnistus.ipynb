    {
      "cell_type": "markdown",
      "source": [
        "Kokeillaan neljää eri mallin kokoa. Tiny, base, small ja medium. Mitataan myös suoritusaika."
      ],
      "metadata": {
        "id": "w-L6kVyn9cS2"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "models = [\"openai/whisper-tiny\", \"openai/whisper-base\", \"openai/whisper-small\", \"openai/whisper-medium\"]\n",
        "\n",
        "for model_name in models:\n",
        "    processor = WhisperProcessor.from_pretrained(model_name)\n",
        "    model = WhisperForConditionalGeneration.from_pretrained(model_name)\n",
        "\n",
        "    inputs = processor(y, sampling_rate=sr, return_tensors=\"pt\")\n",
        "\n",
        "    forced_decoder_ids = processor.get_decoder_prompt_ids(language=\"fi\", task=\"transcribe\") # vaihda language=\"en\" kun kokeilee englannikielistä näytettä\n",
        "\n",
        "    start = time.time()\n",
        "\n",
        "    with torch.no_grad():\n",
        "        predicted_ids = model.generate(\n",
        "            inputs[\"input_features\"],\n",
        "            forced_decoder_ids=forced_decoder_ids\n",
        "        )\n",
        "\n",
        "    end = time.time()\n",
        "    duration = end - start\n",
        "\n",
        "    transcription = processor.batch_decode(predicted_ids, skip_special_tokens=True)[0]\n",
        "\n",
        "    print(f\"\\nDuration: {duration}\")\n",
        "    print(f\"Model: {model_name}\")\n",
        "    print(f\"Text: {transcription}\")"
      ],
